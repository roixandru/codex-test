<% layout('layout') -%>
<form action="/login" method="post" class="max-w-sm mx-auto mt-20 bg-white p-6 shadow">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  <h1 class="text-xl mb-4">Login</h1>
  <% if (flash.error) { %>
    <p class="text-red-500"><%= flash.error %></p>
  <% } %>
  <div class="mb-2">
    <label>Email</label>
    <input type="email" name="email" class="w-full border" />
  </div>
  <div class="mb-2">
    <label>Password</label>
    <input type="password" name="password" class="w-full border" />
  </div>
  <button class="mt-2 bg-blue-500 text-white px-4 py-2">Login</button>
  <p class="mt-2">No account? <a href="/register" class="text-blue-500">Register</a></p>
</form>
